# AutoFlow Environment Variables
# Copy this to .env.local for local development
# Add all of these to your Vercel project's Environment Variables for production

# ─── Database ────────────────────────────────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection string (pooled)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── SMTP Email (Brevo — instant delivery, free 300 emails/day) ──────────────
# Sign up free at https://app.brevo.com → SMTP & API → SMTP tab → Generate SMTP key
# SMTP_USER = your Brevo account email (e.g. your@gmail.com you signed up with)
# SMTP_PASS = the SMTP KEY Brevo generates (long string, NOT your login password)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_brevo_smtp_key

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URIs: https://your-app.vercel.app/api/auth/google-callback
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here

# ─── M-Pesa Daraja API (Safaricom) ───────────────────────────────────────────
# Get from: https://developer.safaricom.co.ke → Create App → Select Lipa Na M-Pesa Sandbox
# For sandbox testing, shortcode = 174379 and passkey is provided in the portal
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey_from_portal

# ─── Application URL ──────────────────────────────────────────────────────────
# Local dev: http://localhost:8080
# Production: your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:8080

# ─── Crypto Payments (Avalanche C-Chain) ─────────────────────────────────────
# VITE_ prefix = exposed to frontend browser code

# The wallet address that receives USDT/USDC payments from customers
# Create a wallet on Trust Wallet or MetaMask and copy the address
# IMPORTANT: Use a dedicated business wallet, NOT your personal wallet
VITE_AUTOFLOW_WALLET=0xYourAvalancheWalletAddressHere

# Optional: override Avalanche RPC (default: https://api.avax.network/ext/bc/C/rpc)
# For higher rate limits, get a free endpoint from https://www.ankr.com or https://infura.io
# VITE_AVAX_RPC=https://api.avax.network/ext/bc/C/rpc

# WalletConnect Project ID (for future mobile wallet support via WalletConnect v2)
# Get from: https://cloud.reown.com → Create Project → Copy Project ID
# Not required for MetaMask/Trust Wallet browser extension (window.ethereum)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# ─── Cloudinary (Photo Uploads) ──────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Settings → Upload → Upload Presets
# Create an UNSIGNED preset named "autoflow_uploads"
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=autoflow_uploads

# ─── Flutterwave (Card Payments) ─────────────────────────────────────────────
# Get from: https://dashboard.flutterwave.com → Settings → API Keys
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxx

# ─── M-Pesa B2C (Owner Payouts) ──────────────────────────────────────────────
# Get from: Daraja portal → M-Pesa Express (B2C) → Test Credentials
# MPESA_SECURITY_CREDENTIAL: RSA-encrypt your initiator password with Safaricom's
# production public key. Do this once and store the result as an env var.
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_SECURITY_CREDENTIAL=your_rsa_encrypted_credential

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
